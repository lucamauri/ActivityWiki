    "services": ["MainConfig", "ActivityWiki.KeyManager"]
  },
  {
    "path": "/activitywiki/outbox",
    "method": "GET",
    "class": "MediaWiki\\Extension\\ActivityWiki\\Rest\\OutboxHandler",
    "services": ["MainConfig"]
  },
  {
    "path": "/activitywiki/followers",
    "method": "GET",
    "class": "MediaWiki\\Extension\\ActivityWiki\\Rest\\FollowersHandler",
    "services": ["MainConfig"]
  },
  {
    "path": "/activitywiki/webfinger",
    "method": "GET",
    "class": "MediaWiki\\Extension\\ActivityWiki\\Rest\\WebFingerHandler",
    "services": ["MainConfig", "ActivityWiki.KeyManager"]
  },
  {
    "path": "/activitywiki/inbox",
    "method": "POST",
    "class": "MediaWiki\\Extension\\ActivityWiki\\Rest\\InboxHandler",
